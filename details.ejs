async function submitReturnRequest(orderId) {
    var reason = document.getElementById('returnReason').value.trim();
    var accountHolder = document.getElementById('returnAccountHolder').value.trim();
    var accountNumber = document.getElementById('returnAccountNumber').value.trim();
    var ifscCode = document.getElementById('returnIFSC').value.trim();
    var bankName = document.getElementById('returnBankName').value.trim();
    var pickupAddress = document.getElementById('returnPickupAddress').value.trim();
    
    if (!reason) return alert('❌ Please enter reason!');
    if (!pickupAddress) return alert('❌ Please enter pickup address!');
    if (!accountHolder || !accountNumber || !ifscCode) return alert('❌ Please fill bank details!');
    
    // ✅ Loading effect - Disable button
    var submitBtn = document.querySelector('#returnFormModal button[onclick*="submitReturnRequest"]');
    if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';
    }
    
    // ✅ Use FormData for image upload
    var formData = new FormData();
    formData.append('reason', reason);
    formData.append('accountHolder', accountHolder);
    formData.append('accountNumber', accountNumber);
    formData.append('ifscCode', ifscCode);
    formData.append('bankName', bankName);
    formData.append('pickupAddress', pickupAddress);
    
    // ✅ Append images
    var imageFiles = document.getElementById('returnImages')?.files;
    if (imageFiles) {
        for (let i = 0; i < Math.min(imageFiles.length, 3); i++) {
            formData.append('returnImages', imageFiles[i]);
        }
    }
    
    try {
        var r = await fetch('/marketplace/api/order/' + orderId + '/return', {
            method: 'POST',
            body: formData
        });
        var d = await r.json();
        if (d.success) {
            closeReturnForm();
            alert('✅ Return request submitted!');
            location.reload();
        } else {
            alert('❌ ' + (d.error || 'Failed'));
            // ✅ Re-enable button on error
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '✅ Submit Return Request';
            }
        }
    } catch(e) { 
        alert('Error');
        // ✅ Re-enable button on error
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '✅ Submit Return Request';
        }
    }
}
