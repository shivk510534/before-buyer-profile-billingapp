// ✅ View Return Image with Swipe/Next-Back + Keyboard Navigation
var currentImageViewerIndex = 0;
var currentImageViewerUrls = [];

function viewReturnImage(url) {
    var allImages = document.querySelectorAll('.return-proof-img');
    currentImageViewerUrls = [];
    currentImageViewerIndex = 0;
    
    allImages.forEach(function(img, i) {
        var src = img.src || img.getAttribute('src');
        if (src && src !== window.location.href) {
            currentImageViewerUrls.push(src);
            if (src === url) currentImageViewerIndex = i;
        }
    });
    
    if (currentImageViewerUrls.length === 0) {
        currentImageViewerUrls = [url];
    }
    
    var modal = document.createElement('div');
    modal.id = 'imageViewerModal';
    modal.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.95);z-index:99999;display:flex;align-items:center;justify-content:center;';
    
    renderImageInModal(modal);
    document.body.appendChild(modal);
    
    modal.onclick = function(e) {
        if (e.target === modal) modal.remove();
    };
}

function renderImageInModal(modal) {
    var idx = currentImageViewerIndex;
    var urls = currentImageViewerUrls;
    
    modal.innerHTML = `
        <span onclick="document.getElementById('imageViewerModal').remove()" 
              style="position:absolute;top:20px;right:30px;color:#fff;font-size:30px;cursor:pointer;z-index:2;">&times;</span>
        
        ${urls.length > 1 ? `
            <button onclick="event.stopPropagation(); currentImageViewerIndex = currentImageViewerIndex <= 0 ? currentImageViewerUrls.length - 1 : currentImageViewerIndex - 1; renderImageInModal(document.getElementById('imageViewerModal'));" 
                    style="position:absolute;left:20px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);color:#fff;border:1px solid #444;font-size:24px;width:45px;height:45px;border-radius:50%;cursor:pointer;z-index:2;">
                &#10094;
            </button>
            <button onclick="event.stopPropagation(); currentImageViewerIndex = currentImageViewerIndex >= currentImageViewerUrls.length - 1 ? 0 : currentImageViewerIndex + 1; renderImageInModal(document.getElementById('imageViewerModal'));" 
                    style="position:absolute;right:20px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);color:#fff;border:1px solid #444;font-size:24px;width:45px;height:45px;border-radius:50%;cursor:pointer;z-index:2;">
                &#10095;
            </button>
        ` : ''}
        
        <div style="text-align:center;">
            <img src="${urls[idx]}" 
                 style="max-width:90vw;max-height:85vh;object-fit:contain;border-radius:8px;">
            ${urls.length > 1 ? `
                <div style="color:#888;font-size:12px;margin-top:10px;">
                    ${idx + 1} / ${urls.length}
                </div>
            ` : ''}
        </div>
    `;
}

// ⌨️ Keyboard navigation for image viewer
document.addEventListener('keydown', function(e) {
    var modal = document.getElementById('imageViewerModal');
    if (!modal) return;
    
    if (e.key === 'ArrowLeft') {
        e.preventDefault();
        currentImageViewerIndex = currentImageViewerIndex <= 0 ? currentImageViewerUrls.length - 1 : currentImageViewerIndex - 1;
        renderImageInModal(modal);
    }
    if (e.key === 'ArrowRight') {
        e.preventDefault();
        currentImageViewerIndex = currentImageViewerIndex >= currentImageViewerUrls.length - 1 ? 0 : currentImageViewerIndex + 1;
        renderImageInModal(modal);
    }
    if (e.key === 'Escape') {
        modal.remove();
    }
});

// ✅ Return Status Badge Helper
function getReturnStatusBadge(status) {
    const badges = {
        'pending': { color: '#ffaa00', icon: '⏳', text: 'Pending Review' },
        'accepted': { color: '#0088ff', icon: '✅', text: 'Accepted' },
        'approved': { color: '#00cc00', icon: '💰', text: 'Refunded' },
        'rejected': { color: '#ff4444', icon: '❌', text: 'Rejected' }
    };
    const b = badges[status] || badges['pending'];
    return `<span style="display:inline-block;padding:4px 12px;border-radius:15px;font-size:11px;font-weight:600;background:${b.color}20;color:${b.color};border:1px solid ${b.color}40;">${b.icon} ${b.text}</span>`;
}
