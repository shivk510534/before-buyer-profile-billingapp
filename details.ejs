
<!-- views/order-detail.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>Order Details - Marketplace | Billexa</title>
    <meta name="theme-color" content="#00ff00">
    
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        :root {
            --bg: #050508;
            --card: #0f0f15;
            --card2: #111118;
            --green: #00ff41;
            --green-dark: #00cc33;
            --green-glow: rgba(0, 255, 65, 0.5);
            --green-soft: rgba(0, 255, 65, 0.06);
            --red: #ff4444;
            --red-soft: rgba(255, 68, 68, 0.08);
            --orange: #ff9800;
            --blue: #2196f3;
            --text: #e8e8e8;
            --text2: #a0a0b0;
            --text3: #6a6a80;
            --text4: #505060;
            --border: rgba(255, 255, 255, 0.06);
            --border-green: rgba(0, 255, 65, 0.2);
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.4);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            line-height: 1.6;
        }

        h1, h3, .btn {
            font-family: 'Poppins', 'Inter', sans-serif;
        }

        /* ========== CONTAINER ========== */
        .container {
            max-width: 700px;
            margin: 0 auto;
            padding: 20px 16px 40px;
        }

        /* ========== HEADER ========== */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .header h1 {
            font-size: clamp(1.1rem, 3vw, 1.4rem);
            color: var(--green);
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn {
            padding: 10px 16px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 0.78rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 1px solid var(--border);
            cursor: pointer;
            transition: var(--transition);
            font-weight: 500;
            white-space: nowrap;
            min-height: 40px;
            font-family: 'Poppins', 'Inter', sans-serif;
            background: transparent;
            color: var(--text2);
        }
        .btn:hover {
            transform: translateY(-2px);
        }
        .btn:active {
            transform: scale(0.97);
        }
        .btn-back {
            background: var(--card2);
            color: var(--text2);
            border-color: var(--text4);
        }
        .btn-back:hover {
            background: #222;
            color: #fff;
        }
        .btn-invoice {
            background: var(--green);
            color: #000;
            border-color: var(--green);
            font-weight: 700;
        }
        .btn-invoice:hover {
            box-shadow: 0 4px 20px rgba(0, 255, 65, 0.4);
        }
        .btn-update {
            background: var(--green);
            color: #000;
            border: none;
            font-weight: 700;
        }
        .btn-update:hover {
            box-shadow: 0 4px 20px rgba(0, 255, 65, 0.4);
        }

        /* ========== CARD ========== */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 18px 16px;
            margin-bottom: 14px;
            box-shadow: var(--shadow-card);
            transition: var(--transition);
        }
        .card:hover {
            border-color: var(--border-green);
        }

        /* ========== CARD TOP ========== */
        .card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 14px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .order-id {
            font-size: clamp(1rem, 2.5vw, 1.2rem);
            font-weight: 700;
            color: var(--green);
        }
        .order-date {
            font-size: 0.7rem;
            color: var(--text3);
        }

        /* ========== BADGE ========== */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: rgba(0, 255, 65, 0.1);
            border: 1px solid rgba(0, 255, 65, 0.3);
            color: var(--green);
        }
        .badge-cancelled {
            background: rgba(255, 68, 68, 0.1);
            border: 1px solid rgba(255, 68, 68, 0.3);
            color: var(--red);
        }
        .badge-pending {
            background: rgba(255, 152, 0, 0.1);
            border: 1px solid rgba(255, 152, 0, 0.3);
            color: var(--orange);
        }

        /* ========== PROGRESS BAR ========== */
        .progress-section {
            margin: 20px 0 10px;
        }
        .progress-bar {
            display: flex;
            justify-content: space-between;
            position: relative;
            padding: 0 4px;
        }
        .progress-bar::before {
            content: '';
            position: absolute;
            top: 15px;
            left: 15px;
            right: 15px;
            height: 3px;
            background: rgba(255,255,255,0.06);
            z-index: 1;
            border-radius: 2px;
        }
        .progress-fill {
            position: absolute;
            top: 15px;
            left: 15px;
            height: 3px;
            background: var(--green);
            z-index: 2;
            border-radius: 2px;
            transition: width 0.6s ease;
        }
        .step {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 3;
            flex: 1;
            min-width: 0;
        }
        .step-dot {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--card2);
            border: 2px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            margin-bottom: 5px;
            transition: var(--transition);
            color: var(--text4);
        }
        .step.completed .step-dot,
        .step.active .step-dot {
            background: var(--green);
            border-color: var(--green);
            color: #000;
        }
        .step.active .step-dot {
            box-shadow: 0 0 16px var(--green-glow);
        }
        .step-label {
            font-size: 0.58rem;
            color: var(--text4);
            text-align: center;
            font-weight: 500;
            white-space: nowrap;
        }
        .step.completed .step-label,
        .step.active .step-label {
            color: var(--green);
            font-weight: 600;
        }
        .step-time {
            font-size: 0.5rem;
            color: var(--text4);
            text-align: center;
            margin-top: 2px;
        }

        /* ========== INFO ROWS ========== */
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 9px 0;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            font-size: 0.8rem;
            gap: 10px;
        }
        .info-row:last-child {
            border-bottom: none;
        }
        .info-label {
            color: var(--text3);
            font-size: 0.72rem;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .info-value {
            font-weight: 500;
            text-align: right;
            color: #fff;
            font-size: 0.8rem;
            word-break: break-word;
        }
        .amount {
            color: var(--green);
            font-size: clamp(1rem, 2.5vw, 1.2rem);
            font-weight: 700;
            text-shadow: 0 0 10px var(--green-glow);
        }

        /* ========== STATUS HISTORY ========== */
        .status-history {
            margin-top: 12px;
        }
        .status-history h3 {
            font-size: 0.8rem;
            color: var(--text3);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .history-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 7px 0;
            border-bottom: 1px solid rgba(255,255,255,0.02);
            font-size: 0.75rem;
        }
        .history-item:last-child {
            border-bottom: none;
        }
        .history-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--green);
            flex-shrink: 0;
        }
        .history-status {
            color: #fff;
            font-weight: 500;
        }
        .history-time {
            color: var(--text4);
            font-size: 0.65rem;
            margin-left: auto;
            white-space: nowrap;
        }

        /* ========== SELLER SECTION ========== */
        .seller-section {
            display: flex;
            gap: 8px;
            margin-top: 12px;
            flex-wrap: wrap;
            align-items: center;
        }
        .seller-section select {
            padding: 10px 12px;
            background: var(--card2);
            border: 1px solid var(--border);
            color: #fff;
            border-radius: 8px;
            font-size: 0.8rem;
            outline: none;
            font-family: 'Inter', sans-serif;
            min-height: 40px;
            flex: 1;
            min-width: 150px;
            cursor: pointer;
        }
        .seller-section select:focus {
            border-color: var(--green);
            box-shadow: 0 0 10px rgba(0, 255, 65, 0.1);
        }
        .seller-section select option {
            background: #1a1a22;
            color: #fff;
        }

        /* ========== LOADING SPINNER ========== */
        .loading-spinner {
            width: 36px;
            height: 36px;
            border: 3px solid var(--border);
            border-top-color: var(--green);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 40px auto;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ========== EMPTY TEXT ========== */
        .text-muted {
            color: var(--text3);
            font-size: 0.75rem;
        }

        /* ========== MOBILE RESPONSIVE ========== */
        @media (max-width: 480px) {
            .container {
                padding: 14px 10px 30px;
            }
            .header h1 {
                font-size: 1rem;
            }
            .btn {
                padding: 8px 12px;
                font-size: 0.7rem;
                min-height: 36px;
            }
            .card {
                padding: 14px 12px;
                border-radius: var(--radius-md);
            }
            .step-dot {
                width: 24px;
                height: 24px;
                font-size: 0.65rem;
            }
            .step-label {
                font-size: 0.5rem;
            }
            .step-time {
                font-size: 0.45rem;
            }
            .progress-bar::before {
                top: 12px;
                left: 12px;
                right: 12px;
            }
            .progress-fill {
                top: 12px;
                left: 12px;
            }
            .badge {
                padding: 4px 10px;
                font-size: 0.6rem;
            }
            .info-row {
                font-size: 0.72rem;
                padding: 7px 0;
            }
            .info-label {
                font-size: 0.65rem;
            }
            .info-value {
                font-size: 0.72rem;
            }
            .seller-section select {
                padding: 8px 10px;
                font-size: 0.72rem;
                min-height: 36px;
            }
            .history-item {
                font-size: 0.68rem;
                gap: 7px;
            }
            .history-time {
                font-size: 0.6rem;
            }
        }

        @media (min-width: 481px) and (max-width: 768px) {
            .container {
                padding: 18px 20px 35px;
            }
        }

        /* ========== REVIEW SECTION ========== */
.review-card {
    background: var(--card);
    border: 1px solid var(--border-green);
    border-radius: var(--radius-lg);
    padding: 18px 16px;
    margin-top: 14px;
    box-shadow: 0 0 20px rgba(0, 255, 65, 0.05);
}
.review-card h3 {
    font-size: 0.9rem;
    color: var(--green);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.review-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 10px;
}
.review-stars i {
    font-size: 1.4rem;
    cursor: pointer;
    color: #444;
    transition: var(--transition);
}
.review-stars i.active,
.review-stars i:hover {
    color: #ffaa00;
    text-shadow: 0 0 8px rgba(255, 170, 0, 0.5);
}
.review-textarea {
    width: 100%;
    padding: 12px;
    background: var(--card2);
    border: 1px solid var(--border);
    color: #fff;
    border-radius: var(--radius-sm);
    font-size: 0.8rem;
    min-height: 90px;
    resize: vertical;
    font-family: 'Inter', sans-serif;
    outline: none;
    margin-bottom: 8px;
}
.review-textarea:focus {
    border-color: var(--green);
    box-shadow: 0 0 8px rgba(0, 255, 65, 0.1);
}
.review-word-count {
    font-size: 0.65rem;
    color: var(--text3);
    margin-bottom: 8px;
    text-align: right;
}
.review-word-count.warn {
    color: #ff4444;
}
.review-images-preview {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin: 8px 0;
}
.review-images-preview img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 6px;
    border: 1px solid var(--border);
}
.btn-review {
    padding: 10px 20px;
    background: var(--green);
    color: #000;
    border: none;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    font-family: 'Poppins', sans-serif;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: var(--transition);
    margin-top: 8px;
}
.btn-review:hover {
    box-shadow: 0 4px 20px rgba(0, 255, 65, 0.4);
    transform: translateY(-1px);
}
.btn-review:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}
.review-existing {
    background: var(--green-soft);
    border: 1px solid var(--border-green);
    border-radius: var(--radius-md);
    padding: 14px;
    margin-top: 14px;
}
.review-existing .stars {
    color: #ffaa00;
    font-size: 0.9rem;
}
.review-existing p {
    font-size: 0.8rem;
    color: #ddd;
    margin: 6px 0;
}
.review-existing .review-images {
    display: flex;
    gap: 6px;
    margin-top: 6px;
}
.review-existing .review-images img {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
    cursor: pointer;
    border: 1px solid var(--border);
}
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><i class="fas fa-clipboard-list"></i> Order Details</h1>
            <a href="/orders/my" class="btn btn-back"><i class="fas fa-arrow-left"></i> My Orders</a>
        </div>

        <div id="content">
            <div class="loading-spinner"></div>
        </div>
    </div>

       <script>
// 🔔 Auto Session Check - Premium UI Alert (Every 30 seconds)
(function() {
    var lastCheck = 0;
    var kickOverlayShown = false;
    
    function showKickOverlay() {
        if (kickOverlayShown) return;
        kickOverlayShown = true;
        
        var overlay = document.createElement('div');
        overlay.id = 'kickOverlay';
        overlay.innerHTML = `
            <div style="
                position: fixed; top: 0; left: 0; width: 100%; height: 100%;
                background: rgba(5, 5, 8, 0.95); backdrop-filter: blur(20px);
                z-index: 99999; display: flex; align-items: center; justify-content: center;
            ">
                <div style="
                    background: rgba(15, 15, 28, 0.9); border: 1px solid #ff4444;
                    border-radius: 20px; padding: 35px 25px; text-align: center;
                    max-width: 420px; width: 90%; box-shadow: 0 0 50px rgba(255,68,68,0.3);
                    animation: kickPopIn 0.4s ease;
                ">
                    <div style="font-size: 55px; margin-bottom: 10px;">🔐</div>
                    <h3 style="color: #ff4444; font-family: 'Poppins', sans-serif; font-size: 1.3rem; margin: 10px 0;">
                        ⚠️ Session Terminated
                    </h3>
                    <p style="color: #a0a0b0; font-size: 0.9rem; margin: 8px 0; line-height: 1.5;">
                        Your account was opened on <strong style="color: #ff6666;">another device or browser</strong>.
                    </p>
                    <p style="color: #6a6a80; font-size: 0.78rem; margin: 5px 0 15px;">
                        For security, you've been logged out here.
                    </p>
                    <button onclick="window.location.href='/login?kicked=1'" style="
                        width: 100%; padding: 13px; background: linear-gradient(135deg, #ff4444, #cc0000);
                        color: #fff; border: none; border-radius: 50px; font-size: 0.95rem;
                        font-weight: 700; cursor: pointer; font-family: 'Poppins', sans-serif;
                        transition: all 0.3s; box-shadow: 0 4px 25px rgba(255,68,68,0.4);
                    " onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 35px rgba(255,68,68,0.6)';"
                       onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 4px 25px rgba(255,68,68,0.4)';">
                        🔑 Go to Login
                    </button>
                    <p style="color: #4a4a60; font-size: 0.7rem; margin-top: 12px;">
                        Billexa Security &bull; Single Session Protection
                    </p>
                </div>
            </div>
            <style>
                @keyframes kickPopIn {
                    from { opacity: 0; transform: scale(0.9) translateY(-20px); }
                    to { opacity: 1; transform: scale(1) translateY(0); }
                }
            </style>
        `;
        document.body.appendChild(overlay);
    }
    
    setInterval(function() {
        var now = Date.now();
        if (now - lastCheck < 30000) return;
        lastCheck = now;
        
        fetch('/api/session-status', { 
            headers: { 'Cache-Control': 'no-cache' } 
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            if (d.kicked) {
                showKickOverlay();
            }
        })
        .catch(function() {});
    }, 30000);
})();
</script>
  <script>
    // 🔒 Advanced Console Blocker - SECURE
    (function() {
        var realFetch = window.fetch;
        
        Object.defineProperty(window, 'fetch', {
            get: function() {
                return function(url, options) {
                    var stack = new Error().stack || '';
                    var isConsole = false;
                    if (stack.includes('VM')) isConsole = true;
                    if (stack.includes('console')) isConsole = true;
                    if (stack.includes('eval')) isConsole = true;
                    
                    if (isConsole) {
                        console.warn('🚫 Console extraction blocked (fetch)');
                        return new Promise(function(_, reject) {
                            reject(new Error('Blocked'));
                        });
                    }
                    
                    return realFetch(url, options);
                };
            },
            configurable: false,
            enumerable: true
        });
        
        var realXHR = window.XMLHttpRequest;
        window.XMLHttpRequest = function() {
            var stack = new Error().stack || '';
            var isConsole = stack.includes('VM') || stack.includes('console') || stack.includes('eval');
            
            if (isConsole) {
                console.warn('🚫 Console extraction blocked (XHR)');
                throw new Error('Blocked');
            }
            return new realXHR();
        };
        window.XMLHttpRequest.prototype = realXHR.prototype;
        window.XMLHttpRequest.UNSENT = realXHR.UNSENT;
        window.XMLHttpRequest.OPENED = realXHR.OPENED;
        window.XMLHttpRequest.HEADERS_RECEIVED = realXHR.HEADERS_RECEIVED;
        window.XMLHttpRequest.LOADING = realXHR.LOADING;
        window.XMLHttpRequest.DONE = realXHR.DONE;
        
    })();
</script>
    <script>
        const orderId = '<%= orderId %>';
const currentUserId = '<%= session.userId %>'; // ✅ NAYA
const steps = [
    { label: 'Pending', icon: 'fa-clock' },
    { label: 'Confirmed', icon: 'fa-check-circle' },
    { label: 'Packed', icon: 'fa-box' },
    { label: 'Shipped', icon: 'fa-truck' },
    { label: 'Out for Delivery', icon: 'fa-map-marker-alt' },
    { label: 'Delivered', icon: 'fa-check-double' }
];

let selectedRating = 0; // ✅ Upar shift kiya

document.addEventListener('DOMContentLoaded', loadOrder);

async function loadOrder() {
    const content = document.getElementById('content');

    try {
        const res = await fetch(`/orders/api/orders/${orderId}`);
        const data = await res.json();

        if (!data.success) {
            content.innerHTML = `<div class="card"><p class="text-muted"><i class="fas fa-exclamation-circle"></i> ${escapeHtml(data.error || 'Order not found')}</p></div>`;
            return;
        }

        const order = data.order;
        const isSeller = order.sellerId === currentUserId;
        const isBuyer = order.buyerId === currentUserId;
        const currentIdx = steps.findIndex(s => s.label === order.status);
        const progressPct = currentIdx >= 0 ? (currentIdx / (steps.length - 1)) * 100 : 0;
        const allStatuses = ['Pending', 'Confirmed', 'Packed', 'Shipped', 'Out for Delivery', 'Delivered', 'Cancelled'];
        const nextStatuses = order.status === 'Cancelled' ? [] : allStatuses.slice(currentIdx + 1);

        let badgeClass = '';
        let badgeIcon = 'fa-circle';
        if (order.status === 'Cancelled') {
            badgeClass = 'badge-cancelled';
            badgeIcon = 'fa-times-circle';
        } else if (order.status === 'Pending') {
            badgeClass = 'badge-pending';
            badgeIcon = 'fa-clock';
        } else {
            badgeIcon = 'fa-check-circle';
        }

        content.innerHTML = `
            <div class="card">
                <div class="card-top">
                    <div>
                        <div class="order-id">#${escapeHtml(order.orderId)}</div>
                        <div class="order-date"><i class="fas fa-calendar-alt"></i> ${order.createdAtFormatted || new Date(order.createdAt).toLocaleDateString('en-IN')}</div>
                    </div>
                    <span class="badge ${badgeClass}"><i class="fas ${badgeIcon}"></i> ${order.status}</span>
                </div>

                ${order.status !== 'Cancelled' ? `
                <div class="progress-section">
