async function loadReviewSection(orderId, productId) {
    const section = document.getElementById('reviewSection');
    if (!section) return;
    
    try {
        const res = await fetch(`/reviews/api/reviews/${productId}`);
        const data = await res.json();
        
        const existingReview = data.success ? data.reviews.find(r => r.orderId === orderId) : null;
        
        if (existingReview) {
            section.innerHTML = `
                <div class="review-existing">
                    <h4 style="color:var(--green);margin-bottom:6px;">
                        <i class="fas fa-check-circle"></i> Your Review
                    </h4>
                    <div class="stars">${'⭐'.repeat(existingReview.rating)}</div>
                    <p>${escapeHtml(existingReview.review)}</p>
                    ${existingReview.images && existingReview.images.length > 0 ? `
                        <div class="review-images">
                            ${existingReview.images.map(img => 
                                `<img src="${img.url}" onclick="window.open('${img.url}')" alt="Review image">`
                            ).join('')}
                        </div>
                    ` : ''}
                    <small style="color:#666;">${new Date(existingReview.createdAt).toLocaleDateString('en-IN')}</small>
                </div>
            `;
        } else {
            section.innerHTML = `
                <div class="review-card">
                    <h3><i class="fas fa-star"></i> Write a Review</h3>
                    
                    <div class="review-stars" id="starRating">
                        ${[1,2,3,4,5].map(i => 
                            `<i class="fas fa-star" data-rating="${i}" onclick="setRating(${i})" title="${i} Star"></i>`
                        ).join('')}
                    </div>
                    
                    <textarea class="review-textarea" id="reviewText" 
                              placeholder="Share your experience (max 200 words)..."></textarea>
                    <div class="review-word-count" id="wordCount">0/200 words</div>
                    
                    <label style="font-size:0.7rem;color:var(--text3);">
                        <i class="fas fa-image"></i> Add photos (max 2)
                    </label>
                    <input type="file" id="reviewImages" accept="image/*" multiple 
                           style="margin:6px 0;color:var(--text2);font-size:0.7rem;" 
                           onchange="previewReviewImages(event)">
                    <div class="review-images-preview" id="reviewImagesPreview"></div>
                    
                    <button class="btn-review" onclick="submitReview('${orderId}', '${productId}')">
                        <i class="fas fa-paper-plane"></i> Submit Review
                    </button>
                </div>
            `;
            
            document.getElementById('reviewText').addEventListener('input', function() {
                const words = this.value.trim().split(/\s+/).filter(w => w.length > 0).length;
                const wc = document.getElementById('wordCount');
                wc.textContent = `${words}/200 words`;
                wc.className = words > 200 ? 'review-word-count warn' : 'review-word-count';
            });
        }
        
    } catch (err) {
        console.error('Load review section error:', err);
    }
}

function setRating(rating) {
    selectedRating = rating;
    const stars = document.querySelectorAll('#starRating i');
    stars.forEach((star, i) => {
        star.className = i < rating ? 'fas fa-star active' : 'fas fa-star';
    });
}

function previewReviewImages(event) {
    const preview = document.getElementById('reviewImagesPreview');
    if (!preview) return;
    
    preview.innerHTML = '';
    const files = event.target.files;
    
    for (let i = 0; i < Math.min(files.length, 2); i++) {
        const reader = new FileReader();
        reader.onload = (e) => {
            preview.innerHTML += `<img src="${e.target.result}" alt="Preview">`;
        };
        reader.readAsDataURL(files[i]);
    }
}

async function submitReview(orderId, productId) {
    const reviewText = document.getElementById('reviewText')?.value?.trim();
    
    if (!reviewText) return alert('Please write a review');
    if (selectedRating === 0) return alert('Please select a rating');
    
    const words = reviewText.split(/\s+/).filter(w => w.length > 0).length;
    if (words > 200) return alert('Review must be under 200 words');
    
    const btn = document.querySelector('.btn-review');
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Submitting...';
    }
    
    const formData = new FormData();
    formData.append('productId', productId);
    formData.append('orderId', orderId);
    formData.append('rating', selectedRating);
    formData.append('review', reviewText);
    
    const imageFiles = document.getElementById('reviewImages')?.files;
    if (imageFiles) {
        for (let i = 0; i < Math.min(imageFiles.length, 2); i++) {
            formData.append('images', imageFiles[i]);
        }
    }
    
    try {
        const response = await fetch('/reviews/api/review/create', {
            method: 'POST',
            body: formData
        });
        
        const data = await response.json();
        
        if (data.success) {
            alert('✅ Review submitted! Thank you.');
            loadReviewSection(orderId, productId);
        } else {
            alert(data.error || 'Failed to submit review');
        }
    } catch (err) {
        alert('Network error. Please try again.');
    } finally {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Review';
        }
    }
}

