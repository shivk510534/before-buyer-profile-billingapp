function calculateDaysLeft(deadline) {
    if (!deadline) return 0;
    return Math.max(0, Math.ceil((new Date(deadline) - new Date()) / 86400000));
}

// Buyer: Request Return
async function requestReturn(orderId) {
    var reason = prompt('🔄 Reason for return:');
    if (!reason || !reason.trim()) return;
    try {
        var r = await fetch('/marketplace/api/order/' + orderId + '/return', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({reason: reason.trim()})
        });
        var d = await r.json();
        alert(d.success ? '✅ Submitted!' : '❌ ' + (d.error || 'Failed'));
        if (d.success) location.reload();
    } catch(e) { alert('Error'); }
}

// Seller: Show UTR input after clicking Accept
function showUTRInput() {
    document.getElementById('utrForm').style.display = 'block';
}

// Seller: Reject Return
async function rejectReturn(orderId) {
    if (!confirm('❌ Reject this return?')) return;
    try {
        var r = await fetch('/marketplace/api/order/' + orderId + '/handle-return', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: 'reject' })
        });
        var d = await r.json();
        if (d.success) {
            alert('✅ Return rejected!');
            location.reload();
        } else {
            alert('❌ ' + (d.error || 'Failed'));
        }
    } catch(e) { alert('Error'); }
}

// Page load: Update days left countdown
document.addEventListener('DOMContentLoaded', function() {
    fetch('/orders/api/orders/' + orderId).then(r => r.json()).then(d => {
        if (d.success && d.order && d.order.returnDeadline) {
            var el = document.getElementById('daysLeft');
            if (el) { 
                var days = calculateDaysLeft(d.order.returnDeadline); 
                el.textContent = days; 
                if (days <= 2) el.style.color = '#ff4444'; 
            }
        }
    }).catch(() => {});
});

// ==================== CANCEL ORDER ====================
async function cancelOrder(orderId) {
    if (!confirm('⚠️ Cancel this order?\n\nThis cannot be undone!')) return;
    
    try {
        const res = await fetch(`/marketplace/api/order/${orderId}/cancel`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const data = await res.json();
        
        if (data.success) {
            alert('✅ Order cancelled!');
            location.reload();
        } else {
            alert('❌ ' + (data.error || 'Failed to cancel'));
        }
    } catch(e) {
        alert('Network error. Try again.');
    }
}

